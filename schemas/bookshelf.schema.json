{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "project_name",
    "type",
    "units",
    "overall_dimensions",
    "structure",
    "zones"
  ],
  "properties": {
    "project_name": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "units": {
      "type": "string"
    },
    "overall_dimensions": {
      "type": "object",
      "required": [
        "width",
        "height",
        "depth"
      ],
      "properties": {
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "depth": {
          "type": "number"
        }
      }
    },
    "structure": {
      "type": "object",
      "required": [
        "board_thickness"
      ],
      "properties": {
        "board_thickness": {
          "type": "number"
        },
        "side_panels": {
          "type": "boolean"
        },
        "top_panel": {
          "type": "boolean"
        },
        "bottom_panel": {
          "type": "boolean"
        }
      }
    },
    "dividers": {
      "type": "object",
      "properties": {
        "center": {
          "type": "boolean"
        }
      }
    },
    "solver": {
      "type": "object",
      "properties": {
        "remaining_distribution": {
          "type": "string",
          "enum": [
            "none",
            "top_bottom_large",
            "large_openings",
            "uniform"
          ]
        }
      }
    },
    "zones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "clear_height",
          "count"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "clear_height": {
            "type": "number"
          },
          "count": {
            "type": "integer"
          }
        }
      }
    },
    "back_panel": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "thickness": {
          "type": "number"
        },
        "split": {
          "type": "boolean"
        },
        "split_vertical_panels": {
          "type": "boolean"
        },
        "panel_width": {
          "type": "number"
        },
        "panel_height": {
          "type": "number"
        }
      }
    },
    "visualization": {
      "type": "object",
      "properties": {
        "add_dvds": {
          "type": "boolean"
        },
        "dvd_width": {
          "type": "number"
        },
        "dvd_height": {
          "type": "number"
        },
        "dvd_depth": {
          "type": "number"
        },
        "boxset_width": {
          "type": "number"
        },
        "boxset_height": {
          "type": "number"
        },
        "boxset_depth": {
          "type": "number"
        },
        "add_books": {
          "type": "boolean"
        },
        "book_small_width": {
          "type": "number"
        },
        "book_small_height": {
          "type": "number"
        },
        "book_small_depth": {
          "type": "number"
        },
        "book_large_width": {
          "type": "number"
        },
        "book_large_height": {
          "type": "number"
        },
        "book_large_depth": {
          "type": "number"
        },
        "gap": {
          "type": "number"
        }
      }
    }
  }
}